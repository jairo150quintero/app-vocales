<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/start_background">

    <!-- Elemento decorativo superior -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/rounded_button"
        android:alpha="0.2"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/mainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/start_title"
            android:textColor="@color/title_color"
            android:textSize="48sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#40000000"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/subTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/start_subtitle"
            android:textColor="@color/title_color"
            android:textSize="18sp"
            android:gravity="center"
            android:textAlignment="center"
            android:alpha="0.8" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/startButton"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_gravity="center"
            android:background="@drawable/rounded_button"
            android:text="@string/btn_play"
            android:textColor="@color/title_color"
            android:textSize="22sp"
            android:textStyle="bold"
            android:elevation="8dp" />

        <TextView
            android:id="@+id/creditsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_gravity="center"
            android:text="@string/btn_credits"
            android:textColor="@color/title_color"
            android:textSize="14sp"
            android:alpha="0.6"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground" />

        <!-- Imagen unificada de las vocales 3D -->
        <ImageView
            android:id="@+id/imgVocales"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/imagen_vocales"
            android:contentDescription="@string/vowels_display"
            android:scaleType="fitCenter" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
